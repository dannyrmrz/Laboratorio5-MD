depths <- c(3, 5, 7, 10)
rmse_results <- c()
for(d in depths){
modelo <- rpart(price ~ .,
data = train_data,
method = "anova",
control = rpart.control(maxdepth = d))
pred <- predict(modelo, test_data)
rmse_val <- rmse(test_data$price, pred)
rmse_results <- c(rmse_results, rmse_val)
}
data.frame(
profundidad = depths,
RMSE = rmse_results
)
